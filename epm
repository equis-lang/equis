#!/bin/bash

set -euo pipefail

function abspath() {
    local target=$1
    if [ -d "$target" ]; then (cd "$target" && pwd)
    elif [ -f "$target" ]; then (cd "$(dirname "$target")" && echo "$(pwd)/$(basename "$target")")
    else echo "$target"; fi
}
SCRIPT_PATH=$(abspath "$0")
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")

function show_help() {
    cat << EOF
Equis Package Manager (epm) v0.1.0

USAGE:
    epm <COMMAND> [ARGS]

COMMANDS:
    init        Scaffolds a new Equis project
    get <url>   Installs and tracks a remote package
    install     Restores all dependencies from equis.json
    run <file>  Convenience wrapper for 'eq run'
    help        Show this help message

EXAMPLES:
    epm init
    epm get https://github.com/equis-lang/std-extra
    epm install
EOF
}

if [ $# -lt 1 ]; then show_help; exit 0; fi

CMD=$1
shift

case $CMD in
    init)
        if [ -f "equis.json" ]; then echo "Error: equis.json already exists in this directory."; exit 1; fi
        NAME=$(basename "$(pwd)")
        cat << EOF > equis.json
{
  "name": "$NAME",
  "version": "0.1.0",
  "dependencies": {}
}
EOF
        mkdir -p src
        if [ ! -f "src/main.equis" ]; then
            cat << EOF > src/main.equis
use "std/sys.equis";

fn main() {
    print_raw_str("Hello from Equis project: $NAME\n");
}

main();
EOF
        fi
        if [ ! -f ".gitignore" ]; then
            cat << EOF > .gitignore
*.ll
*.o
.equis/
EOF
        fi
        echo "[epm] Initialized Equis project: $NAME"
        ;;
    get)
        if [ -z "${1:-}" ]; then echo "Usage: epm get <repo_url>"; exit 1; fi
        if [ ! -f "equis.json" ]; then echo "Error: No equis.json found. Run 'epm init' first."; exit 1; fi
        REPO=$1
        PKG_NAME=$(basename "$REPO" .git)
        echo "[epm] Fetching $PKG_NAME..."
        mkdir -p .equis/packages
        if [ -d ".equis/packages/$PKG_NAME" ]; then (cd ".equis/packages/$PKG_NAME" && git pull)
        else git clone "$REPO" ".equis/packages/$PKG_NAME"; fi
        if ! grep -q "\"$PKG_NAME\"" equis.json; then
            if grep -q "  \"dependencies\": {}" equis.json; then
                sed -i 's|  "dependencies": {}|  "dependencies": {\n    "'"$PKG_NAME"'": "'"$REPO"'"\n  }|' equis.json
            else
                sed -i '/"dependencies": {/,/}/ s|}|    "'"$PKG_NAME"'": "'"$REPO"'"\n  }|' equis.json
                sed -i '/"'"$PKG_NAME"'":/! s|\(    ".*": ".*"\)$|\1,|' equis.json
            fi
            echo "[epm] Added $PKG_NAME to equis.json"
        fi
        ;;
    install)
        if [ ! -f "equis.json" ]; then echo "Error: equis.json not found."; exit 1; fi
        echo "[epm] Installing dependencies..."
        grep "\": \"http" equis.json | sed -E 's/.*": "(.*)".*/\1/' | while read -r url; do epm get "$url"; done
        ;;
    run)
        if [ -f "$SCRIPT_DIR/eq" ]; then "$SCRIPT_DIR/eq" run "$@"
        else eq run "$@"; fi
        ;;
    help|--help|-h) show_help ;;
    *) echo "[epm] Error: Unknown command '$CMD'. See 'epm help'."; exit 1 ;;
esac
