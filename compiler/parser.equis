}
fn parse_transformation(p) {
    let line = 0;
    let node = 0;
    line = parser_previous(p)[2];
    node = parse_event(p);
    node[AST_TYPE] = STMT_TRANSFORMATION;
    return node;
}
fn parse_valuator(p) {
    let tok = 0;
    let name = 0;
    let v_implements = 0;
    let body = 0;
    let node = 0;
    tok = parser_previous(p); 
    name = parser_consume(p, TOKEN_IDENTIFIER, "Expect Valuator name.");
    v_implements = 0;
    if (parser_match(p, TOKEN_IMPLEMENTS)) {
        v_implements = parser_consume(p, TOKEN_IDENTIFIER, "Expect interface name.")[1];
    }
    parser_consume(p, TOKEN_LBRACE, "Expect '{'.");
    body = parse_block(p);
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = STMT_VALUATOR;
    node[1] = name[1];
