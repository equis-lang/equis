    parser_consume(p, TOKEN_RBRACE, "Expect '}' after Policy block.");
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = STMT_POLICY;
    node[1] = name[1];
    node[2] = body;
    node[3] = tok[2];
    node[4] = tok[3];
    return node;
}
