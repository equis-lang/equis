use "std/sys.equis";
use "std/string.equis";
use "std/collections.equis";
use "compiler/constants.equis";
fn parser_new(tokens) {
    let p = 0;
    p = sys_malloc(8 * 8);
    p[0] = tokens;
    p[1] = 0;
    p[2] = vec_size(tokens);
    p[3] = 0;
    return p;
}
fn parser_is_at_end(p) {
    let tok = 0;
    if (p[1] >= p[2]) { return 1; }
    tok = vec_get(p[0], p[1]);
    return tok[0] == TOKEN_EOF;
}
fn parser_peek(p) {
    return vec_get(p[0], p[1]);
}
fn parser_previous(p) {
    return vec_get(p[0], p[1] - 1);
}
fn parser_advance(p) {
    if (parser_is_at_end(p) == 0) { p[1] = p[1] + 1; }
    return parser_previous(p);
}
fn parser_check(p, type) {
    let tok = 0;
    if (parser_is_at_end(p)) { return 0; }
    tok = parser_peek(p);
    return tok[0] == type;
}
fn parser_match(p, type) {
    if (parser_check(p, type)) {
        parser_advance(p);
        return 1;
    }
    return 0;
}
fn parser_parse_generics(p) {
    if (parser_match(p, TOKEN_LESS)) {
        let list = vec_new(INITIAL_VEC_CAP);
        let more = 1;
        while (more && parser_check(p, TOKEN_IDENTIFIER)) {
            let tok = parser_consume(p, TOKEN_IDENTIFIER, "Expected generic type identifier");
            list = vec_push(list, tok[1]);
            if (parser_match(p, TOKEN_COMMA) == 0) { more = 0; }
        }
        parser_consume(p, TOKEN_GREATER, "Expected '>' after generic parameters");
        return list;
    }
    return 0;
}
fn parser_error(p, msg) {
    let tok = 0;
    tok = parser_peek(p);
    write(2, "error: ", 7);
    write(2, msg, sys_strlen(msg));
    write(2, "\n", 1);
    exit(1);
}
fn parser_consume(p, type, msg) {
    let tok = 0;
    if (parser_check(p, type)) { return parser_advance(p); }
    tok = parser_peek(p);
    write(2, "syntax error: ", 14);
    write(2, msg, sys_strlen(msg));
    write(2, "\n", 1);
    write(2, "  --> line ", 11);
    print_int_stderr(tok[2]);
    write(2, ":", 1);
    print_int_stderr(tok[3]);
    write(2, "\n", 1);
    write(2, "   |\n", 5);
    write(2, "   | Found lexeme '", 19);
    write(2, tok[1], sys_strlen(tok[1]));
    write(2, "' (type ", 8);
    print_int_stderr(tok[0]);
    write(2, ")\n", 2);
    write(2, "   |\n\n", 6);
    exit(1);
}
fn expr_binary(left, op, right, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_BINARY;
    node[BINARY_LEFT] = left;
    node[BINARY_OP] = op;
    node[BINARY_RIGHT] = right;
    node[BINARY_LINE] = line;
    node[BINARY_COL] = col;
    return node;
}
fn expr_literal(val, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_LITERAL;
    node[LITERAL_VAL] = val;
    node[LITERAL_LINE] = line;
    node[LITERAL_COL] = col;
    return node;
}
fn expr_string_literal(val, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_STRING_LITERAL;
    node[LITERAL_VAL] = val;
    node[LITERAL_LINE] = line;
    node[LITERAL_COL] = col;
    return node;
}
fn expr_variable(name, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_VARIABLE;
    node[VAR_NAME] = name;
    node[VAR_LINE] = line;
    node[VAR_COL] = col;
    return node;
}
fn expr_call(callee, args, line, col, generics) {
    let node = 0;
    node = sys_malloc(8 * 8); 
    node[AST_TYPE] = EXPR_CALL;
    node[CALL_CALLEE] = callee;
    node[CALL_ARGS] = args;
    node[CALL_LINE] = line;
    node[CALL_COL] = col;
    node[CALL_GENERICS] = generics;
    return node;
}
fn expr_try(expr, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_TRY;
    node[1] = expr;
    node[2] = line;
    node[3] = col;
    return node;
}
fn expr_index(obj, idx, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_INDEX;
    node[INDEX_OBJ] = obj;
    node[INDEX_IDX] = idx;
    node[INDEX_LINE] = line;
    node[INDEX_COL] = col;
    return node;
}
fn expr_assignment(target, value, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_ASSIGNMENT;
    node[ASSIGN_TARGET] = target;
    node[ASSIGN_VALUE] = value;
    node[ASSIGN_LINE] = line;
    node[ASSIGN_COL] = col;
    return node;
}
fn expr_get(object, name, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = EXPR_GET;
    node[GET_OBJ] = object;
    node[GET_NAME] = name;
    node[GET_LINE] = line;
    node[GET_COL] = col;
    return node;
}
fn stmt_expression(expr, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = STMT_EXPRESSION;
    node[1] = expr;
    node[2] = line;
    node[3] = col;
    return node;
}
fn parse_type(p) {
    let is_fallible = 0;
    if (parser_match(p, TOKEN_QUESTION)) { is_fallible = 1; }
    let type = 0;
    if (parser_match(p, TOKEN_I64)) { type = TOKEN_I64; }
    else if (parser_match(p, TOKEN_F64)) { type = TOKEN_F64; }
    else if (parser_match(p, TOKEN_BOOL)) { type = TOKEN_BOOL; }
    else if (parser_match(p, TOKEN_PTR)) { type = TOKEN_PTR; }
    else if (parser_match(p, TOKEN_IDENTIFIER)) { type = (parser_previous(p))[1]; }
    
    if (parser_match(p, TOKEN_QUESTION)) { is_fallible = 1; }
    return type;
}
fn stmt_let(name, value, type, line, col, is_mut, is_res) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = STMT_LET;
    node[LET_NAME] = name;
    node[LET_VAL] = value;
    node[LET_TYPE] = type;
    node[LET_LINE] = line;
    node[LET_COL] = col;
    node[LET_IS_MUT] = is_mut;
    node[LET_IS_RESOURCE] = is_res;
    return node;
}
fn stmt_if(cond, then, els, line, col) {
    let node = 0;
    node = sys_malloc(8 * 8);
    node[AST_TYPE] = STMT_IF;
    node[IF_COND] = cond;
    node[IF_THEN] = then;
    node[IF_ELSE] = els;
    node[IF_LINE] = line;
    node[IF_COL] = col;
    return node;
}
