use "std/sys.equis";
use "std/fiber.equis";

// Equis v0.1.0: Preemptive Multitasking Verification
// 
// Validates the hardware-timed scheduler and the ability to preempt 
// long-running computations.

// Watcher Fiber
// Verifies that the scheduler can perform periodic checks (heartbeats) 
// while another fiber is occupied.
fn watcher() {
    let mut i = 0;
    while (true) {
        print_raw_str("[Watcher] Heartbeat: ");
        print_raw(i);
        print_raw_str("\n");
        i = i + 1;
        fiber_yield(); // Cooperative yield for demonstration
    }
}

// Heavy Worker Fiber
// This fiber performs intensive logic without explicit yields. 
// The system relies on preemptive switching to maintain responsiveness.
fn busy_worker() {
    print_raw_str("[Worker] Initiating CPU-bound loop...\n");
    let mut x = 0;
    while (true) {
        x = x + 1;
        // Preemption allows the Watcher fiber to run even with zero yields here.
    }
}

fn main() {
    print_raw_str("--- Fiber Preemption Verification ---\n");
    
    // Set preempt interval to 50ms (0.05s)
    sys_fiber_preempt_setup(50); 
    
    // Spawn system fibers
    fiber_spawn(watcher);
    fiber_spawn(busy_worker);
    
    // Observer window
    sys_sleep(2000); // 2s duration for stable verification
    
    print_raw_str("\nTest window complete.\n");
    return 0;
}

main();
