@misc{ibanez_rea_2020,
	location = {Rochester, {NY}},
	title = {{REA}, Triple-Entry Accounting and Blockchain: Converging Paths to Shared Ledger Systems},
	url = {https://papers.ssrn.com/abstract=3602207},
	doi = {10.2139/ssrn.3602207},
	shorttitle = {{REA}, Triple-Entry Accounting and Blockchain},
	abstract = {The concept of shared ledger systems offering a single source of truth has repeatedly called traditional bookkeeping into question. Improving upon the long-standing double-entry system, solutions such as the Resource-Event-Agent ({REA}) accounting framework, triple-entry accounting ({TEA}) and blockchain have been advanced. However, to date, the historical development of these concepts remains murky. This paper conducts a genealogical analysis of shared ledger systems, in particular tracing the development of {REA}, {TEA} and blockchain. We show how the {REA} framework has had a distinct influence on independent streams of research in the field of {TEA}, and how this interaction may be traced to the present incarnation of shared ledger systems in blockchain. In doing so, we duly acknowledge the influence of key individuals contributing to this development, correct common misconceptions and map out how the paths of {REA}, {TEA} and blockchain overlap in the realm of shared ledger systems.},
	number = {3602207},
	publisher = {Social Science Research Network},
	author = {Ibañez, Juan Ignacio and Bayer, Dr Chris N. and Tasca, Paolo and Xu, Jiahua},
	urldate = {2026-05-04},
	date = {2020-05-15},
	langid = {english},
	keywords = {Blockchain, Distributed Ledger Technology, {REA} Accounting Model, Single Source of Truth, Triple-Entry Accounting},
	file = {Full Text PDF:C\:\\Users\\ASUS\\Zotero\\storage\\KV6HVJVV\\Ibañez et al. - 2020 - REA, Triple-Entry Accounting and Blockchain Converging Paths to Shared Ledger Systems.pdf:application/pdf},
